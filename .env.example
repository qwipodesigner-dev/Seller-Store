# Anthropic API key for the "Create SKU with AI" feature.
#
# - Get a key from https://console.anthropic.com/settings/keys
# - Copy this file to `.env.local` and paste the key after the `=`
# - Restart the dev server (Ctrl+C, then `npm run dev`)
#
# WARNING: anything starting with `VITE_` is inlined into the client
# bundle and visible to anyone who opens the page. Use this only for
# local development. For any deployed build, proxy the call through a
# small backend that holds the key server-side.
VITE_ANTHROPIC_API_KEY=
